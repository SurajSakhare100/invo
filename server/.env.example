PORT=5000
NODE_ENV=development

MONGODB_URI=
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGIN=http://localhost:3000

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Test credentials (used when user.sandboxMode = true)
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=your_test_key_secret

# Live credentials (used when user.sandboxMode = false)
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=your_live_key_secret

# Webhook secret — set this in your Razorpay dashboard under Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# URL Razorpay redirects the customer to after payment (optional)
RAZORPAY_CALLBACK_URL=https://yourdomain.com/payment/success

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=payments@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Invo
